@page "/"
@using PCCustomizer.Models
@using PCCustomizer.Models.DTOs
@using System.Diagnostics
@inject IDataService DataService
@inject ICategoryService CategoryService
@inject IMenuService MenuService
@inject IPreferences Preferences
@implements IDisposable

<div @onclick="() => _popoverOpen = false"
     style="display: flex; flex-direction: column; flex: 1 1 0; overflow: hidden; height: 100%;">

    @* 頂部工具列：分類選單 + 菜單操作 *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3" Style="flex-shrink: 0;">
        @* 主分類選單 *@
        <MudSelect T="MyCategoryDTO?" Value="selectedCategory" ValueChanged="OnSelectedCategoryChanged"
                   Label="主分類" Placeholder="選擇主分類"
                   AdornmentColor="Color.Primary" FitContent="false" Clearable="false"
                   Disabled="@DataService.IsLoading" MaxHeight="700"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 280px; max-width: 360px;">
            @if (categories is not null && categories.Any())
            {
                @foreach (var category in categories)
                {
                    <MudSelectItem T="MyCategoryDTO?" Value="@category">
                        @category.CategoryName
                    </MudSelectItem>
                }
            }
        </MudSelect>

        @* 分類摘要 *@
        @if (selectedCategory is not null)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @selectedCategory.Summary
            </MudText>
        }

        <MudSpacer />

        @* 更新資料按鈕 *@
        <MudTooltip Text="從網路更新原價屋商品資料">
            <MudIconButton Icon="@Icons.Material.Outlined.CloudSync" Color="Color.Default"
                           OnClick="UpdateData" Disabled="@DataService.IsLoading" />
        </MudTooltip>

        @* 新增菜單 *@
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.Add"
                   OnClick="AddNewCategory" Disabled="@DataService.IsLoading">
            新增菜單
        </MudButton>

        @* 菜單選擇下拉：有菜單且至少一個未送出才顯示 *@
        @if (MenuService.MenuCategories is not null && MenuService.MenuCategories.Any(m => !m.IsSend))
        {
            <MudSelect T="MenuCategory?" Value="currentMenuCategory" ValueChanged="OnCurrentMenuChanged"
                       Label="選擇菜單" Variant="Variant.Outlined" Margin="Margin.Dense"
                       FitContent="true" Disabled="@DataService.IsLoading" Style="min-width: 130px;">
                @foreach (var menu in MenuService.MenuCategories)
                {
                    <MudSelectItem T="MenuCategory?" Value="@menu" Disabled="@menu.IsSend">
                        @menu.Name
                    </MudSelectItem>
                }
            </MudSelect>
        }

        @* 當前菜單 Popover *@
        @if (currentMenuCategory is not null)
        {
            <CurrentMenuPopover CurrentMenuCategory="@currentMenuCategory"
                                MenuItems="@myMenus"
                                @bind-IsOpen="_popoverOpen"
                                IsLoading="@DataService.IsLoading" />
        }
    </MudStack>

    @* 商品內容區 *@
    <div style="flex: 1 1 0; min-height: 0; overflow: hidden; display: flex;">
        <ProductContent Subcategories="@subcategories" SelectedCategory="@selectedCategory"
                        CurrentMenuCategory="@currentMenuCategory" />
    </div>

</div>

<MudScrollToTop>
    <MudFab Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.ArrowUpward" />
</MudScrollToTop>

@code {
    private List<MyCategoryDTO> categories = new();
    private List<MySubcategoryDTO> subcategories = new();
    private Dictionary<string, List<MenuProduct>> myMenus = new();
    private MenuCategory? currentMenuCategory = null;

    // 這是真正儲存值的私有欄位 (小寫開頭)
    private MyCategoryDTO? selectedCategory;
    // 同步更新 selectedCategory 與 subcategories，供初始化和 DataService 完成後共用
    private void SetSelectedCategory(MyCategoryDTO? value)
    {
        selectedCategory = value;

        if (selectedCategory is null)
        {
            subcategories = new List<MySubcategoryDTO>();
        }
        else
        {
            Preferences.Set("LastCategoryId", selectedCategory.CategoryId);
            subcategories = (categories?.FirstOrDefault(c => c.CategoryId == selectedCategory.CategoryId)?.Subcategories ?? new List<MySubcategoryDTO>())
                .OrderBy(s => s.CategoryId).ToList();
        }
    }

    // 使用者切換主分類時：顯示遮罩 → 讓 Blazor 渲染空狀態 → 更新資料 → 關遮罩
    private async Task OnSelectedCategoryChanged(MyCategoryDTO? value)
    {
        // 清空子分類並顯示遮罩，讓 MudTabs 先消失
        selectedCategory = value;
        subcategories = new List<MySubcategoryDTO>();
        DataService.SetGlobalLoading(true, "商品資訊載入中...");
        await Task.Yield();

        SetSelectedCategory(value);
        DataService.SetGlobalLoading(false);
    }
    private bool _popoverOpen = false;

    protected override async Task OnInitializedAsync()
    {
        // 訂閱事件
        DataService.OnStateChanged += HandleDataStateChanged;
        MenuService.OnStateChanged += HandleMenuStateChanged;

        // 取得菜單資料（不依賴商品資料）
        myMenus = await MenuService.GetDictMyMenu(currentMenuCategory);
        await MenuService.GetMenuCategoriesAsync();

        // 還原上次選擇的菜單（只選未送出的；若全部已送出則保持 null）
        if (MenuService.MenuCategories is not null && MenuService.MenuCategories.Any(m => !m.IsSend))
        {
            var lastMenuId = Preferences.Get("LastMenuId", -1);
            currentMenuCategory = MenuService.MenuCategories.FirstOrDefault(m => m.Id == lastMenuId && !m.IsSend)
                               ?? MenuService.MenuCategories.First(m => !m.IsSend);
            Preferences.Set("LastMenuId", currentMenuCategory?.Id ?? -1);
        }

        // 若 DataService 此時已完成，直接載入商品並關閉遮罩
        // 若仍在載入中，HandleDataStateChanged 會在完成時觸發載入並關閉遮罩
        if (!DataService.IsLoading)
        {
            await LoadCategoriesAndRestoreSelectionAsync();
            DataService.SetGlobalLoading(false);
        }

        await base.OnInitializedAsync();
    }

    // 從 DB 載入分類資料並還原上次選擇的分類，可被初始化和 DataService 完成事件共用
    private async Task LoadCategoriesAndRestoreSelectionAsync()
    {
        categories = await CategoryService.GetCategoriesWithDetailsAsync(currentMenuCategory);
        myMenus = await MenuService.GetDictMyMenu(currentMenuCategory);

        if (categories.Any())
        {
            var lastCategoryId = Preferences.Get("LastCategoryId", -1);
            SetSelectedCategory(categories.FirstOrDefault(c => c.CategoryId == lastCategoryId)
                               ?? categories.First());
        }
    }

    // 這是 MudSelect 的 ValueChanged 事件處理常式
    private async Task OnCurrentMenuChanged(MenuCategory? newMenu)
    {
        // 1. 手動更新私有欄位的值
        currentMenuCategory = newMenu;

        // 2. 記住選擇的菜單
        Preferences.Set("LastMenuId", newMenu?.Id ?? -1);

        // 3. 執行非同步邏輯：重新載入 categories (這會包含新菜單的 Qty)
        categories = await CategoryService.GetCategoriesWithDetailsAsync(currentMenuCategory);
        myMenus = await MenuService.GetDictMyMenu(currentMenuCategory);

        // 4. 同步更新 subcategories
        if (selectedCategory is not null)
        {
            subcategories = (categories?.FirstOrDefault(c => c.CategoryId == selectedCategory.CategoryId)?.Subcategories ?? new List<MySubcategoryDTO>())
                .OrderBy(s => s.CategoryId).ToList();
        }

        // 5. 通知 Blazor 畫面需要重新渲染
        await InvokeAsync(StateHasChanged);
    }

    //更新原價屋價格資料
    // _isManualUpdate 旗標防止 HandleDataStateChanged 重複載入
    private bool _isManualUpdate = false;
    private async Task UpdateData()
    {
        _isManualUpdate = true;
        try
        {
            // 先清空選擇，讓 MudTabs 消失，避免後續中間渲染導致 panel 累積
            SetSelectedCategory(null);
            await DataService.SeedDataIfNeededAsync();
            // 更新完成後重新載入資料並還原分類選擇
            categories = await CategoryService.GetCategoriesWithDetailsAsync(currentMenuCategory);
            myMenus = await MenuService.GetDictMyMenu(currentMenuCategory);
            if (categories.Any())
            {
                var lastCategoryId = Preferences.Get("LastCategoryId", -1);
                SetSelectedCategory(categories.FirstOrDefault(c => c.CategoryId == lastCategoryId)
                                   ?? categories.First());
            }
        }
        finally
        {
            _isManualUpdate = false;
            // 手動更新完成，HandleDataStateChanged 被跳過，需在此關閉遮罩
            DataService.SetGlobalLoading(false);
        }
    }

    //新增菜單
    private async Task AddNewCategory()
    {
        await MenuService.AddMenuCategory();

        // 新增後，若目前沒有選中的菜單（例如第一次新增），自動選取最新建立的那一個
        if (currentMenuCategory == null || !MenuService.MenuCategories.Any(m => m.Id == currentMenuCategory.Id))
        {
            currentMenuCategory = MenuService.MenuCategories.LastOrDefault(m => !m.IsSend)
                                ?? MenuService.MenuCategories.LastOrDefault();
            Preferences.Set("LastMenuId", currentMenuCategory?.Id ?? -1);
        }

        StateHasChanged();
    }

    // 當 DataService 的 IsLoading 狀態改變時觸發
    // 僅用於啟動時的自動載入（MainLayout 的 fire-and-forget SeedDataIfNeededAsync）
    // 手動更新（UpdateData）由 UpdateData 自己完整處理，此處跳過
    private async void HandleDataStateChanged()
    {
        // 手動更新時完全不干預，避免中間狀態渲染導致 MudTabs panel 累積
        if (_isManualUpdate) return;

        if (DataService.IsLoading) return;

        // DataService 完成（IsLoading false），重新載入商品資料並關閉全域遮罩
        try
        {
            await InvokeAsync(async () =>
            {
                await LoadCategoriesAndRestoreSelectionAsync();
                DataService.SetGlobalLoading(false);
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"HandleDataStateChanged 發生錯誤: {ex.Message}");
            DataService.SetGlobalLoading(false);
        }
    }

    // 當 MenuService 變更時 (例如新增/更新產品)，這個方法會被呼叫
    private async void HandleMenuStateChanged()
    {
        try
        {
            // 1. 若所有菜單都已送出，清空當前菜單選擇
            if (MenuService.MenuCategories is null || !MenuService.MenuCategories.Any(m => !m.IsSend))
            {
                currentMenuCategory = null;
                Preferences.Set("LastMenuId", -1);
            }

            // 2. 重新呼叫 GetCategoriesWithDetailsAsync，這會重新產生 DTO 列表，並正確計算所有產品的 Qty
            categories = await CategoryService.GetCategoriesWithDetailsAsync(currentMenuCategory);
            //更新菜單的簡易資料
            myMenus = await MenuService.GetDictMyMenu(currentMenuCategory);

            // 3. 在 'categories' (新資料) 更新後，強制 'subcategories' 也同步更新
            if (selectedCategory is not null)
            {
                // 重新從 'categories' (新資料) 中提取 'subcategories'
                subcategories = (categories?.FirstOrDefault(c => c.CategoryId == selectedCategory.CategoryId)?.Subcategories ?? new List<MySubcategoryDTO>())
                    .OrderBy(s => s.CategoryId).ToList();
            }

            // 4. 告訴 Blazor 重新渲染畫面
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"HandleMenuStateChanged 發生錯誤: {ex.Message}");
        }
    }

    public void Dispose()
    {
        // 確保在 Dispose 時也移除所有訂閱
        DataService.OnStateChanged -= HandleDataStateChanged;
        MenuService.OnStateChanged -= HandleMenuStateChanged;
    }
}

