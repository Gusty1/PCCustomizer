@page "/menu"
@using PCCustomizer.Models
@using PCCustomizer.Models.DTOs
@inject IMenuService MenuService
@inject IDialogService DialogService
@inherits BaseComponent
@implements IDisposable

<PriceAlertText />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="AddNewCategory">
        新增菜單
    </MudButton>
    <MudAlert Severity="Severity.Warning" Dense="true" Class="grow" NoIcon="false">
        生成估價單屬於實驗性功能，盡可能跟官方很像，但不保證可以套用到原價屋網站
    </MudAlert>
</MudStack>

@if (!MyAllMenu.Any())
{
    <MudPaper Class="d-flex flex-column align-center justify-center pa-8" Elevation="0" Style="min-height: 300px;">
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-3">尚未建立任何菜單</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">點擊上方「新增菜單」按鈕開始建立</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var category in MyAllMenu)
        {
            <MudItem xs="12" lg="6">
                <MudCard Elevation="3" Outlined="true"
                         Style="min-height: 300px; max-height: 600px; display: flex; flex-direction: column;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            @if (currentlyEditingCardId == category.Id)
                            {
                                <MudTextField @bind-Value="category.Name" Label="菜單名稱"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" />
                            }
                            else
                            {
                                <MudStack Spacing="0">
                                <MudText Typo="Typo.h6">@category.Name</MudText>
                                @if (!category.IsSend)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        點擊右側編輯按鈕即可修改菜單內容
                                    </MudText>
                                }
                            </MudStack>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (currentlyEditingCardId == category.Id && !MenuService.IsLoading)
                            {
                                <MudTooltip Text="儲存">
                                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success"
                                                   OnClick="@(() => SaveChanges(category))" />
                                </MudTooltip>
                                <MudTooltip Text="取消">
                                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Warning"
                                                   OnClick="@(() => CancelEdit(category))" />
                                </MudTooltip>
                            }
                            else
                            {
                                @if (category.IsSend)
                                {
                                    <MudTooltip Text="開啟網頁">
                                        <MudIconButton Icon="@Icons.Material.Filled.WebAsset" Color="Color.Tertiary"
                                                       OnClick="@(() => OpenExternalLink(category.HtmUrl))" />
                                    </MudTooltip>
                                    <MudTooltip Text="開啟圖片">
                                        <MudIconButton Icon="@Icons.Material.Filled.Image" Color="Color.Tertiary"
                                                       OnClick="@(() => OpenExternalLink(category.PngUrl))" />
                                    </MudTooltip>
                                }
                                @if (!MenuService.IsLoading)
                                {
                                    <MudTooltip Text="編輯">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                       OnClick="@(() => StartEditing(category))" />
                                    </MudTooltip>
                                    <MudTooltip Text="刪除菜單">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       OnClick="@(() => DeleteMenu(category))" />
                                    </MudTooltip>
                                }
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Style="flex: 1 1 0; overflow: hidden; display: flex; flex-direction: column;">
                        @if (category is not null && category.MyMenuProducts.Any())
                        {
                            <MudSimpleTable Dense="true" Hover="true" Bordered="true"
                                            Striped="true" FixedHeader="true"
                                            Style="flex: 1 1 0; overflow: auto;">
                                <thead>
                                    <tr>
                                        <th>類別</th>
                                        <th>商品</th>
                                        <th>價格</th>
                                        <th>數量</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (key, value) in category.MyMenuProducts)
                                    {
                                        @for (int i = 0; i < value.Count; i++)
                                        {
                                            var item = value[i];
                                            @if (i == 0)
                                            {
                                                <tr>
                                                    <td rowspan="@value.Count">@key</td>
                                                    <td>@item.ProductName</td>
                                                    <td>@item.ProductPrice.ToString("N0")</td>
                                                    <td>
                                                        <MudStack Row="true" AlignItems="AlignItems.Center">
                                                            <MudNumericField T="int" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                             Style="width:80px;" Step="1" Min="1"
                                                                             @bind-Value="item.Qty"
                                                                             Disabled="@(currentlyEditingCardId != category.Id || category.IsSend)" />
                                                            @if (currentlyEditingCardId == category.Id)
                                                            {
                                                                <MudIconButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                                                               Icon="@Icons.Material.Filled.Delete"
                                                                               OnClick="@(() => DeleteProduct(item))"
                                                                               Disabled="@(DeleteProducts.Any(x => x.Id == item.Id) || category.IsSend)" />
                                                            }
                                                        </MudStack>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td>@item.ProductName</td>
                                                    <td>@item.ProductPrice.ToString("N0")</td>
                                                    <td>
                                                        <MudStack Row="true" AlignItems="AlignItems.Center">
                                                            <MudNumericField T="int" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                             Style="width:80px;" Step="1" Min="1"
                                                                             @bind-Value="item.Qty"
                                                                             Disabled="@(currentlyEditingCardId != category.Id || category.IsSend)" />
                                                            @if (currentlyEditingCardId == category.Id)
                                                            {
                                                                <MudIconButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                                                               Icon="@Icons.Material.Filled.Delete"
                                                                               OnClick="@(() => DeleteProduct(item))"
                                                                               Disabled="@(DeleteProducts.Any(x => x.Id == item.Id) || category.IsSend)" />
                                                            }
                                                        </MudStack>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <div style="flex: 1; display: flex; align-items: center; justify-content: center;">
                                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body1" Color="Color.Secondary">沒有任何商品</MudText>
                                </MudStack>
                            </div>
                        }
                    </MudCardContent>
                    <MudCardActions Class="flex-column pa-3" Style="flex-shrink: 0;">
                        <MudStack Row="true" Style="width: 100%;">
                            <MudText Typo="Typo.subtitle1" Color="Color.Info">
                                總計: <b>@(category.MyMenuProducts.Sum(k => k.Value.Sum(p => p.Qty)))</b> 項商品
                            </MudText>
                            <MudSpacer />
                            <MudText Typo="Typo.subtitle1" Color="Color.Info">
                                總金額: <b>$@(category.MyMenuProducts.Sum(k => k.Value.Sum(p => p.ProductPrice * p.Qty)).ToString("N0"))</b>
                            </MudText>
                        </MudStack>
                        @if (MenuService.IsLoading)
                        {
                            <div style="display: flex; justify-content: center; padding: 8px 0;">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                            </div>
                        }
                        else
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Style="width: 100%;" Class="mt-1">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">最後異動時間</MudText>
                                    <MudText Typo="Typo.body2">@category.ReviseDate?.ToString("yyyy/MM/dd HH:mm")</MudText>
                                </MudStack>
                                <MudSpacer />
                                @if (!category.IsSend && currentlyEditingCardId != category.Id)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Send"
                                               OnClick="() => SendMenu(category.Id)"
                                               Disabled="@(!category.MyMenuProducts.Any())">
                                        生成估價單
                                    </MudButton>
                                }
                            </MudStack>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<MudScrollToTop>
    <MudFab Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.ArrowCircleUp" />
</MudScrollToTop>

@code {
    private List<MyMenuCategoryDTO> MyAllMenu = [];
    private List<MenuProduct> DeleteProducts = [];

    // 追蹤要修改的菜單狀態
    private int? currentlyEditingCardId = null;
    private string originalCategoryName = "";

    protected override async Task OnInitializedAsync()
    {
        MenuService.OnStateChanged += StateHasChanged;
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();

        await base.OnInitializedAsync();
    }

    //新增菜單
    private async Task AddNewCategory()
    {
        await MenuService.AddMenuCategory();
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
    }

    // 開始編輯
    private void StartEditing(MyMenuCategoryDTO category)
    {
        // 儲存原始名稱，以便取消
        DeleteProducts = [];
        originalCategoryName = category.Name;
        currentlyEditingCardId = category.Id;
    }

    // 儲存變更
    private async Task SaveChanges(MyMenuCategoryDTO category)
    {
        // 1. 更新資料庫
        await MenuService.UpdateMenuCategoryAsync(category, DeleteProducts);

        // 2. 退出編輯模式
        DeleteProducts = [];
        currentlyEditingCardId = null;
        originalCategoryName = "";

        // 3. 重新載入資料以確認
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
    }

    // 取消編輯
    private void CancelEdit(MyMenuCategoryDTO category)
    {
        if (category == null) return;
        // 還原名稱
        category.Name = originalCategoryName;
        //還原要刪除的產品
        DeleteProducts = [];
        // 退出編輯模式
        currentlyEditingCardId = null;
        originalCategoryName = "";
    }

    //刪除產品
    private void DeleteProduct(MenuProduct product)
    {
        DeleteProducts.Add(product);
    }

    //送出估價單
    private async Task SendMenu(int menuId)
    {
        await MenuService.SendMenu(menuId);
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
        var category = MyAllMenu.FirstOrDefault(x => x.Id == menuId);
        CancelEdit(category);
    }

    //刪除菜單
    private async Task DeleteMenu(MyMenuCategoryDTO menuCategory)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "確認刪除",
            $"您確定要刪除 {menuCategory.Name} 嗎？此操作無法復原。",
            yesText: "確定刪除",
            noText: "取消"
        );

        if (result == true)
        {
            await MenuService.DeleteMenuCategory(menuCategory.Id);
            MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
        }
    }

    public void Dispose()
    {
        MenuService.OnStateChanged -= StateHasChanged;
    }
}

