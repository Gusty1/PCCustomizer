@page "/menu"
@using PCCustomizer.Models
@using PCCustomizer.Models.DTOs
@inject IMenuService MenuService
@inject IDialogService DialogService
@inherits BaseComponent
@implements IDisposable

<div style="height: 100%; overflow-y: auto; display: flex; flex-direction: column;">

@* 頂部工具列 *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Outlined.Add" OnClick="AddNewCategory">
        新增菜單
    </MudButton>
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        生成估價單為實驗性功能，不保證可套用至原價屋網站
    </MudText>
</MudStack>

@if (!MyAllMenu.Any())
{
    <MudPaper Class="d-flex flex-column align-center justify-center pa-8" Elevation="0" Style="min-height: 300px;">
        <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-3">尚未建立任何菜單</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">點擊上方「新增菜單」按鈕開始建立</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        @foreach (var category in MyAllMenu)
        {
            <MudCard Elevation="1" Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        @if (currentlyEditingCardId == category.Id)
                        {
                            <MudTextField @ref="_nameFieldRefs[category.Id]"
                                          Value="@category.Name" Label="菜單名稱"
                                          ValueChanged="@((string v) => category.Name = v)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px;"
                                          Immediate="true"
                                          @onkeydown="@(async e => { if (e.Key == "Enter") await SaveChanges(category); })" />
                        }
                        else
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.h6">@category.Name</MudText>
                                @if (category.IsSend)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">已送出</MudChip>
                                }
                            </MudStack>
                        }
                    </CardHeaderContent>
                    <CardHeaderActions>
                        @if (currentlyEditingCardId == category.Id && !MenuService.IsLoading)
                        {
                            <MudTooltip Text="儲存">
                                <MudIconButton Icon="@Icons.Material.Outlined.Save" Color="Color.Success"
                                               OnClick="@(() => SaveChanges(category))" />
                            </MudTooltip>
                            <MudTooltip Text="取消">
                                <MudIconButton Icon="@Icons.Material.Outlined.Cancel" Color="Color.Warning"
                                               OnClick="@(() => CancelEdit(category))" />
                            </MudTooltip>
                        }
                        else
                        {
                            @if (category.IsSend)
                            {
                                <MudTooltip Text="開啟估價網頁">
                                    <MudIconButton Icon="@Icons.Material.Outlined.OpenInBrowser" Color="Color.Primary"
                                                   OnClick="@(() => OpenExternalLink(category.HtmUrl))" />
                                </MudTooltip>
                                <MudTooltip Text="開啟估價圖片">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Image" Color="Color.Primary"
                                                   OnClick="@(() => OpenExternalLink(category.PngUrl))" />
                                </MudTooltip>
                            }
                            @if (!MenuService.IsLoading)
                            {
                                <MudTooltip Text="編輯">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Color="Color.Default"
                                                   OnClick="@(() => StartEditing(category))" />
                                </MudTooltip>
                                <MudTooltip Text="刪除菜單">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Error"
                                                   OnClick="@(() => DeleteMenu(category))" />
                                </MudTooltip>
                            }
                        }
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (category is not null && category.MyMenuProducts.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Bordered="false"
                                        Striped="false" FixedHeader="true">
                            <thead>
                                <tr>
                                    <th style="width: 120px;">類別</th>
                                    <th>商品</th>
                                    <th style="width: 100px; text-align: right;">價格</th>
                                    <th style="width: 130px;">數量</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (key, value) in category.MyMenuProducts)
                                {
                                    @for (int i = 0; i < value.Count; i++)
                                    {
                                        var item = value[i];
                                        @if (i == 0)
                                        {
                                            <tr>
                                                <td rowspan="@value.Count" style="vertical-align: top; padding-top: 10px;">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@key</MudText>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.ProductUrl))
                                                    {
                                                        <MudLink Href="@item.ProductUrl" Target="_blank" Color="Color.Primary" Typo="Typo.body2">
                                                            @item.ProductName
                                                        </MudLink>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                                    }
                                                </td>
                                                <td style="text-align: right;">
                                                    <MudText Typo="Typo.body2">$@item.ProductPrice.ToString("N0")</MudText>
                                                </td>
                                                <td>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudNumericField T="int" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                         Style="width:75px;" Step="1" Min="1"
                                                                         @bind-Value="item.Qty"
                                                                         Disabled="@(currentlyEditingCardId != category.Id || category.IsSend)" />
                                                        @if (currentlyEditingCardId == category.Id)
                                                        {
                                                            <MudIconButton Size="Size.Small" Color="Color.Error"
                                                                           Icon="@Icons.Material.Outlined.Remove"
                                                                           OnClick="@(() => DeleteProduct(item))"
                                                                           Disabled="@(DeleteProducts.Any(x => x.Id == item.Id) || category.IsSend)" />
                                                        }
                                                    </MudStack>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.ProductUrl))
                                                    {
                                                        <MudLink Href="@item.ProductUrl" Target="_blank" Color="Color.Primary" Typo="Typo.body2">
                                                            @item.ProductName
                                                        </MudLink>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                                    }
                                                </td>
                                                <td style="text-align: right;">
                                                    <MudText Typo="Typo.body2">$@item.ProductPrice.ToString("N0")</MudText>
                                                </td>
                                                <td>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudNumericField T="int" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                         Style="width:75px;" Step="1" Min="1"
                                                                         @bind-Value="item.Qty"
                                                                         Disabled="@(currentlyEditingCardId != category.Id || category.IsSend)" />
                                                        @if (currentlyEditingCardId == category.Id)
                                                        {
                                                            <MudIconButton Size="Size.Small" Color="Color.Error"
                                                                           Icon="@Icons.Material.Outlined.Remove"
                                                                           OnClick="@(() => DeleteProduct(item))"
                                                                           Disabled="@(DeleteProducts.Any(x => x.Id == item.Id) || category.IsSend)" />
                                                        }
                                                    </MudStack>
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="pa-4">
                            <MudIcon Icon="@Icons.Material.Outlined.ShoppingCartCheckout" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">此菜單尚無商品</MudText>
                        </MudStack>
                    }
                </MudCardContent>
                <MudCardActions Class="px-4 pb-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Style="width: 100%;" Spacing="2">
                        @* 統計資訊 *@
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @(category.MyMenuProducts.Sum(k => k.Value.Sum(p => p.Qty))) 項商品
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">·</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Primary">
                            <b>$@(category.MyMenuProducts.Sum(k => k.Value.Sum(p => p.ProductPrice * p.Qty)).ToString("N0"))</b>
                        </MudText>
                        @if (category.ReviseDate.HasValue && !MenuService.IsLoading)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                                @category.ReviseDate.Value.ToString("yyyy/MM/dd HH:mm")
                            </MudText>
                        }
                        <MudSpacer />
                        @if (MenuService.IsLoading)
                        {
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                        }
                        else if (!category.IsSend && currentlyEditingCardId != category.Id)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.Send"
                                       OnClick="() => SendMenu(category.Id)"
                                       Disabled="@(!category.MyMenuProducts.Any())">
                                生成估價單
                            </MudButton>
                        }
                    </MudStack>
                </MudCardActions>
            </MudCard>
        }
    </MudStack>
}

<MudScrollToTop>
    <MudFab Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.ArrowUpward" />
</MudScrollToTop>

</div>

@code {
    private List<MyMenuCategoryDTO> MyAllMenu = [];
    private List<MenuProduct> DeleteProducts = [];

    // 追蹤要修改的菜單狀態
    private int? currentlyEditingCardId = null;
    private string originalCategoryName = "";

    // 每張卡片名稱輸入框的參考，用於自動 focus
    private readonly Dictionary<int, MudTextField<string>> _nameFieldRefs = new();
    // 記錄下次 render 後要 focus 的卡片 Id
    private int? _pendingFocusId = null;

    protected override async Task OnInitializedAsync()
    {
        MenuService.OnStateChanged += StateHasChanged;
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();

        await base.OnInitializedAsync();
    }

    //新增菜單
    private async Task AddNewCategory()
    {
        await MenuService.AddMenuCategory();
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
    }

    // 開始編輯
    private void StartEditing(MyMenuCategoryDTO category)
    {
        // 儲存原始名稱，以便取消
        DeleteProducts = [];
        originalCategoryName = category.Name;
        currentlyEditingCardId = category.Id;
        // 標記下次 render 後要 focus 此卡片的輸入框
        _pendingFocusId = category.Id;
    }

    // 切換到編輯模式後，自動 focus 名稱輸入框
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingFocusId.HasValue &&
            _nameFieldRefs.TryGetValue(_pendingFocusId.Value, out var field) &&
            field is not null)
        {
            _pendingFocusId = null;
            await field.FocusAsync();
        }
    }

    // 儲存變更
    private async Task SaveChanges(MyMenuCategoryDTO category)
    {
        // 1. 更新資料庫
        await MenuService.UpdateMenuCategoryAsync(category, DeleteProducts);

        // 2. 退出編輯模式
        DeleteProducts = [];
        currentlyEditingCardId = null;
        originalCategoryName = "";

        // 3. 重新載入資料以確認
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
    }

    // 取消編輯
    private void CancelEdit(MyMenuCategoryDTO category)
    {
        if (category == null) return;
        // 還原名稱
        category.Name = originalCategoryName;
        //還原要刪除的產品
        DeleteProducts = [];
        // 退出編輯模式
        currentlyEditingCardId = null;
        originalCategoryName = "";
    }

    //刪除產品
    private void DeleteProduct(MenuProduct product)
    {
        DeleteProducts.Add(product);
    }

    //送出估價單
    private async Task SendMenu(int menuId)
    {
        await MenuService.SendMenu(menuId);
        MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
        // 送出後直接重置編輯狀態，不透過 CancelEdit，
        // 因為 CancelEdit 會將 originalCategoryName（空字串）覆蓋到新載入的名稱
        currentlyEditingCardId = null;
        originalCategoryName = "";
        DeleteProducts = [];
    }

    //刪除菜單
    private async Task DeleteMenu(MyMenuCategoryDTO menuCategory)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "確認刪除",
            $"您確定要刪除 {menuCategory.Name} 嗎？此操作無法復原。",
            yesText: "確定刪除",
            noText: "取消"
        );

        if (result == true)
        {
            await MenuService.DeleteMenuCategory(menuCategory.Id);
            MyAllMenu = await MenuService.GetMyMenuCategoryDTOs();
        }
    }

    public void Dispose()
    {
        MenuService.OnStateChanged -= StateHasChanged;
    }
}

