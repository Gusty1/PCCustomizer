@inherits PCCustomizer.Components.BaseComponent
@inject IDialogService DialogService

<MudStack Row="true" AlignItems="AlignItems.Center" Class="grow my-2" Spacing="2" Style="flex-shrink: 0;">
    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
               @onclick="OpenComputerInfoDialogAsync" StartIcon="@Icons.Material.Filled.Computer">
        我的電腦資訊
    </MudButton>
    <MudAlert Severity="Severity.Warning" Dense="true" Class="grow" NoIcon="false">
        商品價格不保證一定是最新的，價格請以
        <MudLink OnClick="@(() => OpenExternalLink("https://www.coolpc.com.tw/evaluate.php"))"
                 Color="Color.Info">
            原價屋
        </MudLink>
        官網為準
    </MudAlert>
</MudStack>

@code {
    private Task OpenComputerInfoDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        return DialogService.ShowAsync<ComputerInfoDialog>("MyComputerInfo Dialog", options);
    }
}
