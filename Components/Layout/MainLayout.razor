@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService ThemeService
@inject IDataService DataService
@inject IHardwareService HardwareService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

@* 根據 ThemeService 的狀態，應用全域主題 *@
<MudThemeProvider Theme="@ThemeService.CurrentTheme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight: 600; letter-spacing: 0.5px;">
            組電腦小幫手
        </MudText>
        <MudSpacer />
        @* 商品價格警示連結 *@
        <MudTooltip Text="價格僅供參考，以原價屋官網為準">
            <MudIconButton Icon="@Icons.Material.Outlined.Info" Color="Color.Inherit"
                           OnClick="@(() => OpenExternalLink("https://www.coolpc.com.tw/evaluate.php"))" />
        </MudTooltip>
        @* 我的電腦資訊 *@
        <MudTooltip Text="我的電腦資訊">
            <MudIconButton Icon="@Icons.Material.Outlined.Computer" Color="Color.Inherit"
                           OnClick="OpenComputerInfoDialogAsync" />
        </MudTooltip>
        @* 深色/淺色模式 *@
        <MudTooltip Text="@(ThemeService.IsDarkMode ? "切換淺色模式" : "切換深色模式")">
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Inherit" OnClick="@(() => ThemeService.ToggleDarkMode(!ThemeService.IsDarkMode))" />
        </MudTooltip>
    </MudAppBar>

    @* 固定展開的側邊導覽列（Persistent + Open=true 實現固定不收合） *@
    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0"
               ClipMode="DrawerClipMode.Always">
        <MyNavMenu />
    </MudDrawer>

    <MudMainContent Class="d-flex flex-column" Style="height: 100%; overflow: hidden;">
        <MudContainer MaxWidth="MaxWidth.False" Class="flex-grow-1 d-flex flex-column pa-4" Style="min-height: 0; height: 100%; overflow: hidden;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@* 載入遮罩：獨立元件，自行訂閱 DataService，不會觸發整個 Layout 重新渲染 *@
<LoadingOverlay />

@code {
    protected override async Task OnInitializedAsync()
    {
        await ThemeService.LoadThemeAsync();
        ThemeService.OnChange += StateHasChanged;
        _ = DataService.SeedDataIfNeededAsync();
        _ = HardwareService.ScanComputerInfoAsync();
        await base.OnInitializedAsync();
    }

    public void Dispose()
    {
        ThemeService.OnChange -= StateHasChanged;
    }

    private Task OpenComputerInfoDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        return DialogService.ShowAsync<ComputerInfoDialog>("我的電腦資訊", options);
    }

    private Task OpenExternalLink(string url)
    {
        return JSRuntime.InvokeVoidAsync("open", url, "_blank").AsTask();
    }
}
